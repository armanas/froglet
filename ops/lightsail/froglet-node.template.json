{
  "serviceName": "froglet-node",
  "containers": {
    "froglet": {
      "image": "{{IMAGE}}",
      "command": [],
      "environment": {
        "FROGLET_NETWORK_MODE": "clearnet",
        "FROGLET_PUBLIC_BASE_URL": "https://ai.froglet.dev",
        "FROGLET_LISTEN_ADDR": "0.0.0.0:8080",
        "FROGLET_RUNTIME_LISTEN_ADDR": "127.0.0.1:8081",
        "FROGLET_PAYMENT_BACKENDS": "none",
        "RUST_LOG": "info",
        "TZ": "UTC"
      },
      "ports": {
        "8080": "HTTP"
      }
    }
  },
  "publicEndpoint": {
    "containerName": "froglet",
    "containerPort": 8080,
    "healthCheck": {
      "path": "/health",
      "successCodes": "200",
      "intervalSeconds": 30,
      "timeoutSeconds": 5,
      "healthyThreshold": 2,
      "unhealthyThreshold": 3
    }
  }
}
