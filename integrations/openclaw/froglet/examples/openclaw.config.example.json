{
  "plugins": {
    "load": {
      "paths": [
        "/absolute/path/to/froglet/integrations/openclaw/froglet"
      ]
    },
    "entries": {
      "froglet": {
        "enabled": true,
        "config": {
          "runtimeUrl": "http://127.0.0.1:8081",
          "runtimeAuthTokenPath": "/absolute/path/to/froglet/data/runtime/auth.token",
          "requestTimeoutMs": 10000,
          "defaultSearchLimit": 10,
          "maxSearchLimit": 50
        }
      }
    }
  },
  "agents": {
    "list": [
      {
        "id": "main",
        "tools": {
          "allow": [
            "froglet"
          ]
        }
      }
    ]
  }
}
