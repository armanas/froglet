{
  "plugins": {
    "load": {
      "paths": [
        "/sandbox/froglet/integrations/openclaw/froglet"
      ]
    },
    "entries": {
      "froglet": {
        "enabled": true,
        "config": {
          "hostProduct": "nemoclaw",
          "baseUrl": "https://node.example",
          "authTokenPath": "/sandbox/.openclaw/froglet-control.token",
          "requestTimeoutMs": 15000,
          "defaultSearchLimit": 10,
          "maxSearchLimit": 50
        }
      }
    }
  }
}
