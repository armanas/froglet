{
  "id": "froglet",
  "name": "Froglet",
  "version": "0.1.0",
  "description": "Single-tool Froglet integration for generic execution services.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "anyOf": [
      {
        "required": ["baseUrl", "authTokenPath"]
      },
      {
        "required": ["providerUrl", "runtimeUrl", "providerAuthTokenPath", "runtimeAuthTokenPath"]
      },
      {
        "required": ["providerUrl", "runtimeUrl", "authTokenPath"]
      }
    ],
    "properties": {
      "hostProduct": {
        "type": "string",
        "enum": ["openclaw", "nemoclaw"],
        "default": "openclaw"
      },
      "providerUrl": {
        "type": "string",
        "description": "Froglet provider API base URL."
      },
      "runtimeUrl": {
        "type": "string",
        "description": "Froglet runtime API base URL."
      },
      "baseUrl": {
        "type": "string",
        "description": "Legacy unified Froglet control API base URL. When set, it is used for both providerUrl and runtimeUrl."
      },
      "providerAuthTokenPath": {
        "type": "string",
        "description": "Filesystem path to the Froglet provider control API bearer token."
      },
      "runtimeAuthTokenPath": {
        "type": "string",
        "description": "Filesystem path to the Froglet runtime API bearer token."
      },
      "authTokenPath": {
        "type": "string",
        "description": "Legacy shared bearer token path used as a fallback for both providerAuthTokenPath and runtimeAuthTokenPath."
      },
      "requestTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 60000,
        "default": 10000
      },
      "defaultSearchLimit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 50,
        "default": 10
      },
      "maxSearchLimit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 200,
        "default": 50
      }
    }
  }
}
