{
  "id": "froglet",
  "name": "Froglet",
  "version": "0.1.0",
  "description": "Single-tool Froglet integration for OpenClaw and NemoClaw.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["baseUrl", "authTokenPath"],
    "properties": {
      "hostProduct": {
        "type": "string",
        "enum": ["openclaw", "nemoclaw"],
        "default": "openclaw"
      },
      "baseUrl": {
        "type": "string",
        "description": "Unified Froglet control API base URL."
      },
      "authTokenPath": {
        "type": "string",
        "description": "Filesystem path to the Froglet control API bearer token."
      },
      "requestTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 60000,
        "default": 10000
      },
      "defaultSearchLimit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 50,
        "default": 10
      },
      "maxSearchLimit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 200,
        "default": 50
      }
    }
  }
}
