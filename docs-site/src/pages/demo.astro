---
import '../styles/custom.css';
import '../styles/demo-page.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ThemeProvider from '../components/ThemeProvider.astro';
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Demo · Froglet</title>
<meta name="description" content="Interactive Froglet demo — explore identity, deals, and settlement live in the browser." />
<link rel="canonical" href="https://froglet.dev/demo/" />
<meta name="color-scheme" content="dark" />
<!-- OpenGraph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Froglet" />
<meta property="og:title" content="Demo · Froglet" />
<meta property="og:description" content="Interactive Froglet demo — explore identity, deals, and settlement live in the browser." />
<meta property="og:url" content="https://froglet.dev/demo/" />
<meta property="og:image" content="https://froglet.dev/og/default.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Demo · Froglet" />
<meta name="twitter:description" content="Interactive Froglet demo — explore identity, deals, and settlement live in the browser." />
<meta name="twitter:image" content="https://froglet.dev/og/default.png" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<ThemeProvider />

</head>
<body>
	<SiteHeader currentPath={Astro.url.pathname} />
	<div class="demo-shell">
	<div class="main">
	  <div id="scene">
	    <canvas id="net" role="img" aria-label="Animated whiteboard illustrating the current protocol step"></canvas>
	  </div>
	  <div id="lesson-wrap">
	    <div id="lesson-card"></div>
	    <div id="annotation"></div>
	  </div>
	  <div id="term">
	      <div id="term-bar">
	        <div class="traffic"><div class="tl tl-close"></div><div class="tl tl-min"></div><div class="tl tl-max"></div></div>
	        <div id="term-title">froglet &#8212; zsh</div>
	      </div>
	      <div id="term-body"></div>
	    </div>
</div>
<div id="nav">
  <div class="pips" id="pips"></div>
  <button id="prevBtn">Back</button>
  <button id="nextBtn">Continue</button>
</div>
</div>
<SiteFooter />

<script>
  import { initDemo } from '../scripts/demo/index';
  initDemo();
</script>
</body>
</html>
