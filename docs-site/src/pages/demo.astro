---
import '../styles/custom.css';
import '../styles/demo-page.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ThemeProvider from '../components/ThemeProvider.astro';
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Froglet — Interactive Demo</title>
<meta name="color-scheme" content="dark">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;500;600;700&family=Source+Serif+4:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap">
<ThemeProvider />

</head>
<body>
	<SiteHeader currentPath={Astro.url.pathname} />
	<div class="demo-shell">
	<div class="main">
	  <div id="scene">
	    <canvas id="net" role="img" aria-label="Animated whiteboard illustrating the current protocol step"></canvas>
	  </div>
	  <div id="lesson-wrap">
	    <div id="lesson-card"></div>
	    <div id="annotation"></div>
	  </div>
	  <div id="term">
	      <div id="term-bar">
	        <div class="traffic"><div class="tl tl-close"></div><div class="tl tl-min"></div><div class="tl tl-max"></div></div>
	        <div id="term-title">froglet &#8212; zsh</div>
	      </div>
	      <div id="term-body"></div>
	    </div>
</div>
<div id="nav">
  <div class="pips" id="pips"></div>
  <button id="prevBtn">Back</button>
  <button id="nextBtn">Continue</button>
</div>
</div>
<SiteFooter />

<script>
  import { initDemo } from '../scripts/demo/index';
  initDemo();
</script>
</body>
</html>
