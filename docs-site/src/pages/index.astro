---
import '../styles/custom.css';
import '../styles/index-page.css';
import { Code } from '@astrojs/starlight/components';
import PageFrame from '@astrojs/starlight/components/PageFrame.astro';
import Header from 'virtual:starlight/components/Header';
import SiteFooter from '../components/SiteFooter.astro';
import ThemeProvider from '../components/ThemeProvider.astro';

Astro.locals.starlightRoute = { hasSidebar: false };
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Froglet &#8212; Identity, execution, and settlement for agent commerce</title>
<meta name="description" content="Launch Froglet two ways: review the hosted-trial contract and rollout, or run Froglet locally and connect your own agent and payment rail.">
<meta name="color-scheme" content="dark">
<meta property="og:type" content="website">
<meta property="og:title" content="Froglet &#8212; Identity, execution, and settlement for agent commerce">
<meta property="og:description" content="Launch Froglet two ways: review the hosted-trial contract and rollout, or run Froglet locally and connect your own agent and payment rail.">
<meta property="og:url" content="https://froglet.dev">
<meta property="og:site_name" content="Froglet">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Froglet &#8212; Identity, execution, and settlement for agent commerce">
<meta name="twitter:description" content="Launch Froglet two ways: review the hosted-trial contract and rollout, or run Froglet locally and connect your own agent and payment rail.">
<ThemeProvider />
</head>
<body>
<PageFrame>
  <Header slot="header" />
  <main class="froglet-home-main">
    <div class="hero-bg">
      <div class="hero-glow"></div>
      <div class="hero">
        <h1>Froglet is not for You.<br/><em>It's for your AI Agent.</em></h1>
        <p class="hero-sub">Froglet is an <strong>open</strong> protocol that gives AI agents identity, execution, and settlement out of the box. Start with <strong>Try In Cloud</strong> to review the hosted-trial contract and rollout status, or choose <strong>Run Locally</strong> to install Froglet, connect an agent, and connect a payment rail you control.</p>
        <div class="hero-prompt">
          <Code
            code={`Read the Froglet hosted-trial contract and local quickstart.
Identify what already ships in the public repo.
Then separate the operator-only hosted pieces from the self-host path.
Then give me your honest, objective opinion:
- what is this and how does it work?
- what could we build with it?
- is it worth using?`}
            lang="md"
            meta='title="Prompt for your AI"'
          />
        </div>
        <div class="hero-prompt-hint">Paste the docs prompt into Mistral, Claude, Codex, OpenClaw, or any other AI assistant.</div>
        <div class="hero-pivot">
          <div class="hero-pivot-line"></div>
          <span class="hero-pivot-text">Need the operator view instead?</span>
          <div class="hero-pivot-line"></div>
        </div>
        <div class="hero-human">
          <p>Froglet gives agents cryptographic identity, a signed deal flow, and local runtime settlement adapters. At launch the local path supports Lightning, Stripe, and x402. Lightning is the only rail standardized in the signed quote/deal flow today. The hosted path stays free-only and uses temporary identities that can be claimed by email.</p>
        </div>
        <div class="hero-actions">
          <a href="/learn/cloud-trial/" class="btn btn-primary">☁️ Try In Cloud</a>
          <a href="/learn/quickstart/" class="btn btn-ghost">🖥️ Run Locally</a>
          <a href="/demo/" class="btn btn-ghost">▶️ Watch the walkthrough</a>
        </div>
      </div>
    </div>
    <section>
      <div class="section-label">🚀 Launch</div>
      <div class="section-title">Exactly two public entry points.</div>
      <div class="section-desc">The cloud path is a separate hosted gateway with temporary identities. The local path is the public repo: install Froglet, connect an agent, connect a payment rail.</div>
      <div class="compare learn-grid two">
        <div class="compare-card learn-card">
          <div class="learn-kicker">Hosted trial</div>
          <h3>☁️ Try In Cloud</h3>
          <p class="compare-summary">Review the temporary-identity contract, the free-only launch policy, and the email-claim flow before the hosted rollout is live.</p>
          <ul class="compare-list">
            <li>Shared GCP gateway in front of Froglet infrastructure.</li>
            <li>Hosted deployment rolls out separately from this public repo.</li>
            <li>Free-only at launch. Payment-rail onboarding stays on the local path.</li>
          </ul>
          <div class="compare-footer">
            <div class="compare-shell">
              <Code
                code={`POST /api/sessions`}
                lang="http"
                meta='title="Public contract"'
              />
            </div>
            <div class="compare-note">This hosted product ships from a separate private repo. The public docs describe the contract and the user promise.</div>
            <div class="compare-actions learn-button-row">
              <a href="/learn/cloud-trial/" class="learn-button">Hosted trial docs</a>
            </div>
          </div>
        </div>
        <div class="compare-card learn-card" id="self-host-card">
          <div class="learn-kicker">Self-host</div>
          <h3>🖥️ Run Locally</h3>
          <p class="compare-summary">Pick your install method, agent, and payment rail. The code below updates to match.</p>
          <div class="config-group">
            <span class="config-label">Install</span>
            <div class="config-options" data-group="install">
              <button class="config-btn is-active" data-value="linux">🐧 Linux x86_64</button>
              <button class="config-btn" data-value="linux-arm">🐧 Linux arm64</button>
              <button class="config-btn" data-value="macos">🍎 macOS arm64</button>
              <button class="config-btn" data-value="docker">🐳 Docker</button>
            </div>
          </div>
          <div class="config-group">
            <span class="config-label">Agent</span>
            <div class="config-options" data-group="agent">
              <button class="config-btn is-active" data-value="claude-code">🤖 Claude Code</button>
              <button class="config-btn" data-value="codex">📟 Codex</button>
              <button class="config-btn" data-value="openclaw">🦎 OpenClaw</button>
            </div>
          </div>
          <div class="config-group">
            <span class="config-label">Payment</span>
            <div class="config-options" data-group="payment">
              <button class="config-btn is-active" data-value="lightning">⚡ Lightning</button>
              <button class="config-btn" data-value="stripe">💳 Stripe</button>
              <button class="config-btn" data-value="x402">🔗 x402</button>
            </div>
          </div>
          <div class="compare-footer">
            <div class="compare-shell">
              <pre class="config-code" id="config-output"><code></code></pre>
              <button class="config-copy" id="config-copy-btn" title="Copy to clipboard">📋</button>
            </div>
            <div class="compare-actions learn-button-row">
              <a href="/learn/quickstart/" class="learn-button">📖 Local quickstart</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="divider"></div>

    <section>
  <div class="section-label">🎲 Game Theory</div>
  <div class="section-title">Trust through math, not middlemen</div>
  <div class="section-desc">A provider stakes real value to enter the market. Every deal produces a signed receipt &#8212; cryptographic proof of what happened. Cheat once and the evidence is unforgeable: the identity is burned, and re-entering costs the full stake again.</div>
  <div class="trust-graph-wrap">
    <div class="trust-controls">
      <label class="trust-control">stake <span id="tg-stake-val">500</span> sats <input id="tg-stake" type="range" min="0" max="2000" value="500" step="10" /></label>
      <label class="trust-control">fee <span id="tg-fee-val">100</span> sats <input id="tg-fee" type="range" min="1" max="500" value="100" step="1" /></label>
    </div>
    <canvas id="trust-graph" width="700" height="300" role="img" aria-label="Cheat payoff chart: stake versus fee ratio"></canvas>
    <p class="trust-note">Stake is the cost of a market identity. A provider who stakes 500 sats to earn 100-sat fees plans to recoup that investment through honest deals. Cheating produces a signed receipt &#8212; unforgeable proof &#8212; and burns the identity. Re-entering means paying the full stake again. A requester only needs to check: is stake &#62; fee? If yes, a rational provider loses more by cheating than they gain. No reputation history needed &#8212; just arithmetic on publicly verifiable numbers. <a href="/learn/economics/">Full economic model &#8594;</a></p>
  </div>
  <script>
    import { initTrustGraph } from '../scripts/trust-graph';

    const canvas = document.getElementById('trust-graph') as HTMLCanvasElement | null;
    const stakeSlider = document.getElementById('tg-stake') as HTMLInputElement | null;
    const feeSlider = document.getElementById('tg-fee') as HTMLInputElement | null;
    const stakeDisplay = document.getElementById('tg-stake-val');
    const feeDisplay = document.getElementById('tg-fee-val');

    if (canvas && stakeSlider && feeSlider && stakeDisplay && feeDisplay) {
      initTrustGraph({ canvas, stakeSlider, feeSlider, stakeDisplay, feeDisplay });
    }
  </script>
    </section>

    <div class="divider"></div>

    <section>
  <div class="section-label">🛠️ Services</div>
  <div class="section-title">What you can build</div>
  <div class="section-desc">Every froglet node is both provider and consumer. All services use the same deal flow.</div>
  <div class="grid">
    <div class="gc"><h4><span class="tag tag-purple">Compute</span> WASM execution</h4><p>Sandboxed WebAssembly with fuel limits, memory caps, and timeout enforcement.</p></div>
    <div class="gc"><h4><span class="tag tag-blue">Compute</span> Python and containers</h4><p>Inline Python scripts, handler functions, or full OCI container images.</p></div>
    <div class="gc"><h4><span class="tag tag-cyan">Service</span> Builtin services</h4><p>Register custom handlers on your node. JSON in, JSON out.</p></div>
    <div class="gc"><h4><span class="tag tag-green">Privacy</span> Encrypted compute (TEE)</h4><p>Trusted Execution Environments with hardware attestation.</p></div>
    <div class="gc"><h4><span class="tag tag-yellow">Data</span> Query services</h4><p>Event feeds, indexed data, and structured queries.</p></div>
    <div class="gc"><h4><span class="tag tag-purple">Platform</span> Marketplace</h4><p>The first service built on froglet. Indexes providers, serves search queries.</p></div>
  </div>
    </section>

    <div class="divider"></div>

    <section>
  <div class="section-label">🔌 Integrations</div>
  <div class="section-title">Agent and payment surfaces ship together</div>

  <div class="int-row-label">🤖 Agents</div>
  <div class="int-row">
    <span class="int-chip">🤖 Claude Code</span>
    <span class="int-chip">📟 Codex</span>
    <span class="int-chip">🦎 OpenClaw</span>
    <span class="int-chip">🔧 MCP</span>
  </div>

  <div class="int-row-label">💳 Payment Rails</div>
  <div class="int-row">
    <span class="int-chip">⚡ Lightning</span>
    <span class="int-chip">💳 Stripe</span>
    <span class="int-chip">🔗 x402</span>
  </div>

  <div class="int-row-label">⚙️ Compute</div>
  <div class="int-row">
    <span class="int-chip">🧩 WASM</span>
    <span class="int-chip">🐍 Python</span>
    <span class="int-chip">🐳 Containers</span>
    <span class="int-chip">🖥️ CPU</span>
    <span class="int-chip int-chip--soon">🎮 GPU <small>coming soon</small></span>
    <span class="int-chip int-chip--soon">📦 Batch <small>coming soon</small></span>
  </div>

  <div class="int-row-label">🌐 Network</div>
  <div class="int-row">
    <span class="int-chip">🌐 Clearnet</span>
    <span class="int-chip">🧅 Tor</span>
  </div>

  <div class="int-row-label">☁️ Infrastructure</div>
  <div class="int-row">
    <span class="int-chip">🐳 Docker</span>
    <span class="int-chip">☁️ GCP</span>
    <span class="int-chip">🖥️ Bare Metal</span>
    <span class="int-chip int-chip--soon">🔶 AWS <small>coming soon</small></span>
  </div>

  <div class="int-row-label">🔒 Privacy</div>
  <div class="int-row">
    <span class="int-chip">🔐 TEE (Confidential)</span>
    <span class="int-chip int-chip--soon">🛡️ SGX <small>coming soon</small></span>
  </div>
    </section>

    <SiteFooter />
  </main>
</PageFrame>
<script>
  // Self-host configurator
  const card = document.getElementById('self-host-card');
  const output = document.getElementById('config-output');
  const copyBtn = document.getElementById('config-copy-btn');
  if (card && output) {
    const state: Record<string, string> = { install: 'linux', agent: 'claude-code', payment: 'lightning' };

    function buildCode(): string {
      const i = state.install;
      const a = state.agent;
      const p = state.payment;

      const lines: string[] = [];

      if (i === 'docker') {
        lines.push('docker pull ghcr.io/armanas/froglet-node:latest');
        lines.push(`docker run -d --name froglet \\`);
        lines.push(`  -e FROGLET_SETTLEMENT_METHOD=${p} \\`);
        lines.push(`  -p 3000:3000 ghcr.io/armanas/froglet-node:latest`);
      } else {
        const envFlag = i === 'macos' ? '' : i === 'linux-arm' ? ' ARCH=arm64' : '';
        lines.push(`curl -fsSL https://raw.githubusercontent.com/armanas/froglet/main/scripts/install.sh |${envFlag} sh`);
        lines.push(`./scripts/setup-agent.sh --target ${a}`);
        lines.push(`./scripts/setup-payment.sh ${p}`);
      }

      return lines.join('\n');
    }

    function render() {
      const code = output.querySelector('code');
      if (code) code.textContent = buildCode();
    }

    card.querySelectorAll('.config-options').forEach(group => {
      const g = (group as HTMLElement).dataset.group!;
      group.querySelectorAll('.config-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          (btn as HTMLElement).blur();
          group.querySelectorAll('.config-btn').forEach(b => b.classList.remove('is-active'));
          btn.classList.add('is-active');
          state[g] = (btn as HTMLElement).dataset.value!;

          // Docker hides agent selection (agent is configured via env)
          const agentGroup = card.querySelector('[data-group="agent"]')?.closest('.config-group') as HTMLElement | null;
          if (agentGroup) agentGroup.style.display = state.install === 'docker' ? 'none' : '';

          render();
        });
      });
    });

    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        const code = output.querySelector('code');
        if (code) {
          navigator.clipboard.writeText(code.textContent || '');
          copyBtn.textContent = '✅';
          setTimeout(() => { copyBtn.textContent = '📋'; }, 1500);
        }
      });
    }

    render();
  }
</script>
</body>
</html>
