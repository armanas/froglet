---
import '../styles/custom.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ThemeProvider from '../components/ThemeProvider.astro';
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>404 | Froglet</title>
<meta name="color-scheme" content="light dark">
<ThemeProvider />
<style is:inline>
@import url('https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@400;600;700&family=Source+Serif+4:wght@400;600;700&display=swap');
:root{--bg:hsl(var(--froglet-background));--surface:hsl(var(--froglet-card));--border:hsl(var(--froglet-border));--text:hsl(var(--froglet-foreground));--muted:hsl(var(--froglet-muted));--accent:hsl(var(--froglet-accent));--accent-strong:hsl(var(--froglet-accent-strong));--accent-soft:hsl(var(--froglet-accent-soft));--shadow:var(--froglet-shadow)}
*{box-sizing:border-box}
body{margin:0;min-height:100svh;display:flex;flex-direction:column;background:radial-gradient(circle at top,color-mix(in srgb, hsl(var(--froglet-accent)) 8%, transparent),transparent 24%),var(--bg);color:var(--text);font-family:'Inter',system-ui,sans-serif}
.not-found-main{flex:1;display:grid;place-items:center;padding:24px}
.shell{max-width:760px;padding:36px;border:1px solid var(--border);border-radius:28px;background:var(--surface);box-shadow:var(--shadow)}
.pill{display:inline-flex;padding:6px 12px;border-radius:999px;background:var(--accent-soft);border:1px solid color-mix(in srgb, hsl(var(--froglet-accent)) 16%, transparent);color:var(--accent-strong);font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase}
h1{margin:18px 0 12px;font-family:'Inter',system-ui,sans-serif;font-size:clamp(42px,7vw,72px);line-height:.94;letter-spacing:-.04em}
p{margin:0;color:var(--muted);font-size:1.08rem;line-height:1.72;max-width:40rem}
.actions{display:flex;gap:12px;flex-wrap:wrap;margin-top:26px}
.actions a{display:inline-flex;align-items:center;justify-content:center;padding:12px 18px;border-radius:999px;border:1px solid var(--border);color:var(--text);text-decoration:none;font-weight:600;background:var(--surface)}
.actions .primary{background:var(--accent);border-color:var(--accent);color:#f8f6f1}
.actions .primary:hover{background:var(--accent-strong);border-color:var(--accent-strong)}
.actions .ghost:hover{border-color:hsl(var(--froglet-border-strong));background:var(--surface)}
</style>
</head>
<body>
  <SiteHeader currentPath={Astro.url.pathname} />
  <main class="not-found-main">
    <div class="shell">
      <div class="pill">Page not found</div>
      <h1>Wrong path.<br>Right protocol.</h1>
      <p>The page you asked for is missing, but the Learn overview and the interactive demo are still valid entry points.</p>
      <div class="actions">
        <a href="/learn/" class="primary">Learn Froglet</a>
        <a href="/demo/" class="ghost">Open the demo</a>
        <a href="/" class="ghost">Back to home</a>
      </div>
    </div>
  </main>
  <SiteFooter />
</body>
</html>
