---
import '../styles/custom.css';
import '../styles/404-page.css';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ThemeProvider from '../components/ThemeProvider.astro';
---
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>404 · Froglet</title>
<meta name="description" content="Page not found. The docs and interactive demo are still valid entry points." />
<link rel="canonical" href="https://froglet.dev/404" />
<meta name="color-scheme" content="dark" />
<!-- OpenGraph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Froglet" />
<meta property="og:title" content="404 · Froglet" />
<meta property="og:description" content="Page not found. The docs and interactive demo are still valid entry points." />
<meta property="og:url" content="https://froglet.dev/404" />
<meta property="og:image" content="https://froglet.dev/og/default.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="404 · Froglet" />
<meta name="twitter:description" content="Page not found. The docs and interactive demo are still valid entry points." />
<meta name="twitter:image" content="https://froglet.dev/og/default.png" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap">
<ThemeProvider />
</head>
<body>
  <SiteHeader currentPath={Astro.url.pathname} />
  <main class="not-found-main">
    <div class="shell">
      <div class="pill">Page not found</div>
      <h1>Wrong path.<br>Right protocol.</h1>
      <p>The page you asked for is missing, but the docs and interactive demo are still valid entry points.</p>
      <div class="actions">
        <a href="/docs/" class="primary">Open docs</a>
        <a href="/demo/" class="ghost">Open the demo</a>
        <a href="/" class="ghost">Back to home</a>
      </div>
    </div>
  </main>
  <SiteFooter />
</body>
</html>
