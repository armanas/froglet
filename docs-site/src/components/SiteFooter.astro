---
import { navLinks } from '../data/nav-links';

interface Props {
	compact?: boolean;
}

const { compact = false } = Astro.props;
---

<footer class:list={['froglet-site-footer', compact && 'froglet-site-footer--compact']}>
	<div class="froglet-site-footer__inner">
		<div>
			<p class="froglet-site-footer__tagline">🐸 froglet — identity. execution. settlement.</p>
			<p class="froglet-site-footer__credit">Built by <a href="https://armanas.dev" target="_blank" rel="noreferrer">Armanas Povilionis-Muradian</a></p>
		</div>
		<nav class="froglet-site-footer__links" aria-label="Footer">
			{navLinks.map((item) => (
				<a
					href={item.href}
					target={item.external ? '_blank' : undefined}
					rel={item.external ? 'noreferrer' : undefined}
				>
					{item.label}
				</a>
			))}
		</nav>
	</div>
</footer>

<style is:global>
	.froglet-site-footer {
		border-top: 1px solid hsl(var(--froglet-border));
		margin-top: auto;
	}

	.froglet-site-footer__inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(var(--froglet-shell-max-width), calc(100% - (var(--froglet-shell-gutter) * 2)));
		margin: 0 auto;
		padding: 1.1rem 0 1.3rem;
		color: hsl(var(--froglet-muted));
		font-size: 0.88rem;
	}

	.froglet-site-footer--compact .froglet-site-footer__inner {
		width: 100%;
		padding-top: 0.85rem;
	}

	.froglet-site-footer__tagline {
		margin: 0;
	}

	.froglet-site-footer__credit {
		margin: 0.3rem 0 0;
		font-size: 0.8rem;
	}

	.froglet-site-footer__credit a {
		color: hsl(var(--froglet-muted));
		text-decoration: none;
	}

	.froglet-site-footer__credit a:hover {
		color: hsl(var(--froglet-foreground));
	}

	.froglet-site-footer__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
	}

	.froglet-site-footer__links a {
		color: hsl(var(--froglet-muted));
		text-decoration: none;
	}

	.froglet-site-footer__links a:hover {
		color: hsl(var(--froglet-foreground));
	}

	@media (max-width: 720px) {
		.froglet-site-footer__inner {
			flex-direction: column;
			align-items: flex-start;
			padding-block: 1rem 1.1rem;
		}
	}
</style>
