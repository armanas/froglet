---
interface Props {
	compact?: boolean;
}

const { compact = false } = Astro.props;
---

<footer class:list={['site-ftr', compact && 'site-ftr--compact']}>
	<div class="inner">
		<div class="col brand-col">
			<div class="brand" style="align-items: baseline;">
				<span class="mark" style="font-size: 1.2rem;">_o..o_</span>
				froglet
			</div>
			<p>Open protocol for AI agents. MIT licensed.</p>
		</div>
		<div class="col">
			<h5>Product</h5>
			<a href="/docs/">Docs</a>
			<a href="/marketplace/">Marketplace</a>
			<a href="/learn/cloud-trial/">Try in cloud</a>
			<a href="/demo/">Demo</a>
		</div>
		<div class="col">
			<h5>Protocol</h5>
			<a href="/spec/kernel/">Kernel spec</a>
			<a href="/spec/service-binding/">Service binding</a>
			<a href="/learn/economics/">Game theory</a>
			<a href="/architecture/overview/">Architecture</a>
		</div>
		<div class="col">
			<h5>Community</h5>
			<a href="https://github.com/armanas/froglet" target="_blank" rel="noreferrer">GitHub ↗</a>
			<a href="https://github.com/armanas/froglet/discussions" target="_blank" rel="noopener">Discussions</a>
			<a href="/learn/quickstart/">Quickstart</a>
			<a href="/marketplace/overview/">Marketplace docs</a>
		</div>
		<div class="end">
			<span>froglet.dev</span>
		</div>
	</div>
</footer>

<style is:global>
	.site-ftr .brand-col p {
		font-size: 0.8rem;
		color: var(--fg3);
		margin: 12px 0 0;
		max-width: 22ch;
		line-height: 1.5;
	}

	.site-ftr--compact {
		margin-top: 32px;
	}

	@media (max-width: 720px) {
		.site-ftr .inner {
			gap: 24px;
		}
		.site-ftr .end {
			margin-left: 0;
			text-align: left;
		}
	}
</style>
