---
import { navLinks } from '../data/nav-links';

interface Props {
	currentPath?: string;
	embedded?: boolean;
}

const { currentPath = Astro.url.pathname, embedded = false } = Astro.props;

const normalizePath = (path: string) =>
	path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;

const currentPathNormalized = normalizePath(currentPath);

const matchesPrefix = (prefix: string) => {
	if (prefix === '/') return currentPathNormalized === '/';
	const normalizedPrefix = normalizePath(prefix);
	return (
		currentPathNormalized === normalizedPrefix ||
		currentPathNormalized.startsWith(`${normalizedPrefix}/`)
	);
};

const isActive = (item: (typeof navLinks)[number]) => {
	if (item.href.startsWith('http')) return false;
	if (item.activePrefixes?.some(matchesPrefix)) return true;
	return matchesPrefix(item.href);
};

const isExternal = (item: (typeof navLinks)[number]) => item.href.startsWith('http') || item.external;
---

<div class:list={['froglet-site-chrome', embedded && 'froglet-site-chrome--embedded']}>
	<div class="froglet-site-chrome__inner">
		<a href="/" class="froglet-brand" aria-label="Froglet home">
			<span class="froglet-brand__mark" aria-hidden="true">🐸</span>
			<span class="froglet-brand__word">froglet</span>
		</a>
		<nav class="froglet-site-nav" aria-label="Primary">
			{
				navLinks.map((item) => (
					<a
						href={item.href}
						class:list={[
							'froglet-site-nav__link',
							isExternal(item) && 'froglet-site-nav__link--external',
							isActive(item) && 'is-active',
						]}
						target={isExternal(item) ? '_blank' : undefined}
						rel={isExternal(item) ? 'noreferrer' : undefined}
					>
						{item.label}
					</a>
				))
			}
		</nav>
		<div class="froglet-site-tools">
			<slot name="tools" />
		</div>
	</div>
</div>

<style is:global>
	.froglet-site-chrome {
		position: sticky;
		top: 0;
		z-index: 40;
		border-bottom: 1px solid hsl(var(--froglet-border));
		background: color-mix(in srgb, hsl(var(--froglet-background)) 88%, hsl(var(--froglet-surface)) 12%);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
	}

	.froglet-site-chrome--embedded {
		position: static;
		border-bottom: 0;
		background: transparent;
		backdrop-filter: none;
		-webkit-backdrop-filter: none;
	}

	.froglet-site-chrome__inner {
		display: flex;
		align-items: center;
		gap: 1rem;
		width: min(var(--froglet-shell-max-width), calc(100% - (var(--froglet-shell-gutter) * 2)));
		margin: 0 auto;
		min-height: 3.65rem;
	}

	.froglet-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		color: hsl(var(--froglet-foreground));
		text-decoration: none;
		font-family: var(--froglet-font-sans);
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0;
		white-space: nowrap;
	}

	.froglet-brand__mark {
		display: inline-grid;
		width: 1.65rem;
		height: 1.65rem;
		place-items: center;
		border: 1px solid color-mix(in srgb, hsl(var(--froglet-accent)) 24%, transparent);
		border-radius: 50%;
		background: color-mix(in srgb, hsl(var(--froglet-accent-soft)) 72%, transparent);
		font-size: 1.02rem;
		line-height: 1;
	}

	.froglet-brand__word {
		font-family: var(--froglet-font-serif);
		font-size: 1.34rem;
		font-weight: 700;
		line-height: 1;
		letter-spacing: 0;
	}

	.froglet-site-nav {
		display: flex;
		align-items: center;
		gap: 0.3rem;
		margin-left: auto;
	}

	.froglet-site-nav__link {
		padding: 0.48rem 0.72rem;
		border-radius: var(--froglet-card-radius);
		color: hsl(var(--froglet-muted));
		text-decoration: none;
		font-size: 0.88rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		transition:
			background-color 140ms ease,
			color 140ms ease;
	}

	.froglet-site-nav__link:hover {
		background: hsl(var(--froglet-surface));
		color: hsl(var(--froglet-foreground));
	}

	.froglet-site-nav__link.is-active {
		background: hsl(var(--froglet-accent-soft));
		color: hsl(var(--froglet-accent-strong));
	}

	.froglet-site-nav__link--external {
		color: color-mix(in srgb, hsl(var(--froglet-muted)) 78%, transparent);
	}

	.froglet-site-tools {
		display: flex;
		align-items: center;
		gap: 0.65rem;
		margin-left: 0.35rem;
	}

	/* Hide Starlight's built-in mobile menu toggle on desktop where the sidebar
	   is always visible. Restore it on mobile so /learn/* pages remain navigable. */
	@media (min-width: 901px) {
		starlight-menu-button,
		[data-open-sidebar] {
			display: none !important;
		}
	}

	/* On mobile docs pages, keep Starlight's menu button in the header flow and
	   give the sidebar pane an opaque background so it covers page content. */
	@media (max-width: 900px) {
		starlight-menu-button {
			position: static;
			width: auto;
			height: auto;
			display: contents !important;
			border-radius: var(--froglet-card-radius);
			box-shadow: none;
		}

		starlight-menu-button button {
			z-index: 60;
			width: 40px;
			height: 40px;
			border: 1px solid hsl(var(--froglet-border));
			border-radius: var(--froglet-card-radius);
			background: hsl(var(--froglet-surface));
			color: hsl(var(--froglet-foreground));
		}

		nav.sidebar .sidebar-pane {
			background: hsl(var(--froglet-background));
		}
	}

	@media (max-width: 900px) {
		.froglet-site-chrome__inner {
			gap: 0.7rem;
		}

		.froglet-site-nav {
			gap: 0.12rem;
		}

		.froglet-site-nav__link {
			padding-inline: 0.54rem;
			font-size: 0.8rem;
		}

		.froglet-site-nav__link--desktop {
			display: none;
		}
	}

	@media (max-width: 720px) {
		.froglet-site-chrome__inner {
			box-sizing: border-box;
			padding-right: 48px;
		}

		.froglet-site-nav__link--external {
			display: none;
		}
	}

	@media (max-width: 560px) {
		.froglet-brand__mark {
			width: 1.48rem;
			height: 1.48rem;
			font-size: 0.92rem;
		}

		.froglet-brand__word {
			font-size: 1.18rem;
		}

		.froglet-site-chrome__inner {
			gap: 0.5rem;
		}

		.froglet-site-nav__link {
			padding-inline: 0.36rem;
		}
	}
</style>
