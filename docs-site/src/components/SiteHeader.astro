---
import { navLinks } from '../data/nav-links';

interface Props {
	currentPath?: string;
	embedded?: boolean;
}

const { currentPath = Astro.url.pathname, embedded = false } = Astro.props;

const normalizePath = (path: string) =>
	path !== '/' && path.endsWith('/') ? path.slice(0, -1) : path;

const currentPathNormalized = normalizePath(currentPath);

const matchesPrefix = (prefix: string) => {
	if (prefix === '/') return currentPathNormalized === '/';
	const normalizedPrefix = normalizePath(prefix);
	return (
		currentPathNormalized === normalizedPrefix ||
		currentPathNormalized.startsWith(`${normalizedPrefix}/`)
	);
};

const isActive = (item: (typeof navLinks)[number]) => {
	if (item.href.startsWith('http')) return false;
	if ('activePrefixes' in item && item.activePrefixes?.some(matchesPrefix)) return true;
	return matchesPrefix(item.href);
};

const isExternal = (item: (typeof navLinks)[number]) =>
	item.href.startsWith('http') || ('external' in item && item.external);
---

<header class:list={['site-hdr', embedded && 'site-hdr--embedded']}>
	<div class="inner">
		<a href="/" class="brand" aria-label="Froglet home">
			<span class="mark" aria-hidden="true">_o..o_</span>
			froglet
		</a>
		<nav aria-label="Primary">
			{
				navLinks.map((item) => (
					<a
						href={item.href}
						class:list={[
							isActive(item) && 'active',
							'hideOnMobile' in item && item.hideOnMobile && 'mobile-hidden',
						]}
						target={isExternal(item) ? '_blank' : undefined}
						rel={isExternal(item) ? 'noreferrer' : undefined}
					>
						{item.label}
					</a>
				))
			}
		</nav>
		<div class="right">
			<div class="theme-switch" role="group" aria-label="Theme">
				<button type="button" class="theme-switch__btn" data-theme-switch="system" title="System preference" aria-label="Use system theme">
					<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<rect x="2" y="3" width="12" height="8.5" rx="1"></rect>
						<path d="M6 13.5h4M8 11.5v2"></path>
					</svg>
				</button>
				<button type="button" class="theme-switch__btn" data-theme-switch="light" title="Light theme" aria-label="Use light theme">
					<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<circle cx="8" cy="8" r="3"></circle>
						<path d="M8 1.5v1.5M8 13v1.5M1.5 8h1.5M13 8h1.5M3.2 3.2l1 1M11.8 11.8l1 1M3.2 12.8l1-1M11.8 4.2l1-1"></path>
					</svg>
				</button>
				<button type="button" class="theme-switch__btn" data-theme-switch="dark" title="Dark theme" aria-label="Use dark theme">
					<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
						<path d="M13 9.5A5 5 0 0 1 6.5 3a5 5 0 1 0 6.5 6.5z"></path>
					</svg>
				</button>
			</div>
			<a
				class="ghv"
				href="https://github.com/armanas/froglet"
				target="_blank"
				rel="noreferrer"
				aria-label="GitHub"
			>
				<svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
				</svg>
				GitHub
			</a>
			<slot name="tools" />
		</div>
	</div>
</header>

<style is:global>
	.site-hdr--embedded {
		position: static;
		border-bottom: 0;
		background: transparent;
		backdrop-filter: none;
		-webkit-backdrop-filter: none;
	}

	.site-hdr .brand .mark {
		font-size: 14px;
		letter-spacing: 0;
	}

	.site-hdr nav a.mobile-hidden {
		display: inline-flex;
	}

	@media (min-width: 901px) {
		starlight-menu-button,
		[data-open-sidebar] {
			display: none !important;
		}
	}

	@media (max-width: 900px) {
		starlight-menu-button {
			position: static;
			width: auto;
			height: auto;
			display: contents !important;
		}

		starlight-menu-button button {
			z-index: 60;
			width: 40px;
			height: 40px;
			border: 1px solid var(--border);
			border-radius: var(--r-2);
			background: var(--bg-elevated);
			color: var(--fg1);
		}

		nav.sidebar .sidebar-pane {
			background: var(--bg);
		}

		.site-hdr .inner {
			gap: 14px;
		}

		.site-hdr nav {
			gap: 14px;
		}
	}

	@media (max-width: 760px) {
		.site-hdr nav a.mobile-hidden {
			display: none;
		}

		.site-hdr .right .ghv {
			display: none;
		}
	}

	@media (max-width: 560px) {
		.site-hdr .brand .mark {
			font-size: 12px;
		}
		.site-hdr .brand {
			font-size: 13px;
		}
	}
</style>
