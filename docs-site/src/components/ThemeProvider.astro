<script is:inline>
	window.StarlightThemeProvider = (() => {
		const storageKey = 'starlight-theme';
		const systemTheme = () =>
			window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
		const resolveTheme = (value) => (value === 'light' || value === 'dark' ? value : systemTheme());
		const getStoredTheme = () =>
			typeof localStorage !== 'undefined' ? localStorage.getItem(storageKey) : null;
		const applyTheme = (value) => {
			const theme = resolveTheme(value);
			document.documentElement.dataset.theme = theme;
			document.documentElement.style.colorScheme = theme;
			return theme;
		};

		const updateButtons = (theme) => {
			document.querySelectorAll('[data-froglet-theme-toggle]').forEach((button) => {
				if (!(button instanceof HTMLElement)) return;
				button.dataset.mode = theme;
				const nextTheme = theme === 'dark' ? 'light' : 'dark';
				button.setAttribute('aria-pressed', theme === 'dark' ? 'true' : 'false');
				button.setAttribute('aria-label', `Switch to ${nextTheme} mode`);
				button.setAttribute('title', `Switch to ${nextTheme} mode`);
				const label = button.querySelector('[data-froglet-theme-label]');
				if (label) label.textContent = theme === 'dark' ? 'dark' : 'light';
			});
		};

		const updatePickers = (theme = getStoredTheme() || 'auto') => {
			document.querySelectorAll('starlight-theme-select').forEach((picker) => {
				const select = picker.querySelector('select');
				if (select) select.value = theme;
				const tmpl = document.querySelector('#theme-icons');
				const newIcon = tmpl instanceof HTMLTemplateElement
					? tmpl.content.querySelector('.' + theme)
					: null;
				if (newIcon) {
					const oldIcon = picker.querySelector('svg.label-icon');
					if (oldIcon) oldIcon.replaceChildren(...newIcon.cloneNode(true).childNodes);
				}
			});
		};

		const syncTheme = () => {
			const activeTheme = applyTheme(getStoredTheme());
			updateButtons(activeTheme);
			updatePickers(activeTheme);
			return activeTheme;
		};

		const setTheme = (theme) => {
			if (typeof localStorage !== 'undefined') localStorage.setItem(storageKey, theme);
			const activeTheme = applyTheme(theme);
			updateButtons(activeTheme);
			updatePickers(theme);
			document.dispatchEvent(
				new CustomEvent('froglet-theme-change', { detail: { theme: activeTheme } })
			);
			return activeTheme;
		};

		const toggleTheme = () => {
			const currentTheme = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
			return setTheme(currentTheme === 'dark' ? 'light' : 'dark');
		};

		const initialTheme = syncTheme();

		const media = window.matchMedia('(prefers-color-scheme: light)');
		media.addEventListener?.('change', () => {
			const stored = getStoredTheme();
			if (stored !== 'light' && stored !== 'dark') syncTheme();
		});

		document.addEventListener('click', (event) => {
			const toggle = event.target instanceof Element
				? event.target.closest('[data-froglet-theme-toggle]')
				: null;
			if (toggle) toggleTheme();
		});
		document.addEventListener('astro:after-swap', syncTheme);
		document.addEventListener('DOMContentLoaded', syncTheme);

		return { getStoredTheme, setTheme, syncTheme, toggleTheme, updatePickers, initialTheme };
	})();
</script>

<template id="theme-icons">
	<svg class="light" viewBox="0 0 16 16" aria-hidden="true">
		<circle cx="8" cy="8" r="3.4" fill="currentColor"></circle>
		<path
			d="M8 1.2v2.1M8 12.7v2.1M1.2 8h2.1M12.7 8h2.1M3.2 3.2l1.5 1.5M11.3 11.3l1.5 1.5M12.8 3.2l-1.5 1.5M4.7 11.3l-1.5 1.5"
			stroke="currentColor"
			stroke-width="1.3"
			stroke-linecap="round"
		></path>
	</svg>
	<svg class="dark" viewBox="0 0 16 16" aria-hidden="true">
		<path
			d="M10.8 1.6a5.9 5.9 0 1 0 3.6 10.7A6.6 6.6 0 0 1 10.8 1.6Z"
			fill="currentColor"
		></path>
	</svg>
	<svg class="auto" viewBox="0 0 16 16" aria-hidden="true">
		<rect x="2.2" y="3.1" width="11.6" height="8.2" rx="1.6" fill="none" stroke="currentColor" stroke-width="1.2"></rect>
		<path d="M6.6 13h2.8M8 11.3V13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
	</svg>
</template>
