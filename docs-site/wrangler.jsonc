{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "froglet-docs",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-04-22",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "froglet.dev",
      "custom_domain": true
    }
  ]
}
